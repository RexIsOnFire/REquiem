# ReQuiem configuration — copy this file to ".env" and fill in your keys.
#   cp .env.example .env      (or on Windows: copy .env.example .env)
# ReQuiem loads .env automatically at startup (CLI, API, and library).
# Every key is OPTIONAL — leave blank to disable that integration.
# An already-set environment variable always overrides the value here.

# --- Threat intel (hash reputation lookups; metadata only) ---
# VirusTotal API key — https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# MalwareBazaar (abuse.ch) — works without a key; add one to raise rate limits.
# https://auth.abuse.ch/
MALWAREBAZAAR_API_KEY=

# --- CAPE Sandbox (real detonation; you operate the CAPE instance) ---
# Base URL of your CAPE web/API, e.g. https://cape.lan  (no trailing slash needed)
CAPE_URL=
# Optional CAPE API token.
CAPE_TOKEN=
# Max seconds to wait for an analysis, and poll interval.
CAPE_TIMEOUT=600
CAPE_POLL=15
