# ReQuiem configuration — copy this file to ".env" and fill in your keys.
#   cp .env.example .env      (or on Windows: copy .env.example .env)
# ReQuiem loads .env automatically at startup (CLI, API, and library).
# Every key is OPTIONAL — leave blank to disable that integration.
# An already-set environment variable always overrides the value here.
#
# NOTE: In the WEB APP, each signed-in user stores their OWN API keys (encrypted,
# via the Settings page). The keys below are for the CLI / library / single-user
# use. Web users never share these.

# --- Server auth config (web app) ---
# Secret used to sign session tokens and encrypt stored user keys. Set a long
# random value in production. If unset, a persistent one is generated in data/.
REQUIEM_SECRET=
# Set to 1 when serving over HTTPS so the session cookie is marked Secure.
REQUIEM_COOKIE_SECURE=0

# --- Threat intel (hash reputation lookups; metadata only) ---
# VirusTotal API key — https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# MalwareBazaar (abuse.ch) — a free API key is now REQUIRED for hash lookups.
# Sign up (free) and generate one at https://auth.abuse.ch/
MALWAREBAZAAR_API_KEY=

# --- Sandboxes (real detonation; you operate / subscribe to the instance) ---
# Pick one with the CLI: --sandbox {cape,cuckoo,joe,triage}. Any unreachable or
# unconfigured sandbox falls back to the simulated backend automatically.
# NOTE: these example hostnames are PLACEHOLDERS — replace with a real instance
# you run, or leave blank to use the simulated sandbox (the default).

# CAPE Sandbox — https://github.com/kevoreilly/CAPEv2  (you host this yourself)
CAPE_URL=
CAPE_TOKEN=
CAPE_TIMEOUT=600
CAPE_POLL=15

# Cuckoo Sandbox REST API
CUCKOO_URL=
CUCKOO_TOKEN=

# Joe Sandbox (cloud or on-prem)
JOE_URL=
JOE_APIKEY=

# Hatching Triage — https://tria.ge  (TRIAGE_URL defaults to https://tria.ge)
# Also powers by-hash cloud investigation (pulls an EXISTING report, no upload).
TRIAGE_URL=
TRIAGE_TOKEN=

# Hybrid Analysis (Falcon Sandbox) — free research tier, hosted.
# https://www.hybrid-analysis.com/  — used for by-hash cloud investigation.
HYBRIDANALYSIS_API_KEY=

# --- Cloud-by-hash investigation (no local sandbox) ---
# The "Investigate" button / GET /investigate/{hash} pulls any EXISTING cloud
# detonation for a hash from: VirusTotal (VT_API_KEY, behaviour_summary),
# Triage (TRIAGE_TOKEN), and Hybrid Analysis (HYBRIDANALYSIS_API_KEY).
# No file is uploaded and no sample is downloaded. Great for a public deployment.
