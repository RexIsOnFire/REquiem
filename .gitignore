__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
build/
dist/

# Secrets — never commit the real .env (keep .env.example)
.env
.env.local
!.env.example

# User database + server secret (auth) — never commit
data/
*.db
.secret

# Never commit samples or generated reports
samples/*
!samples/.gitkeep
*.exe
*.dll
*.bin
report*.html
report*.json
*.local
